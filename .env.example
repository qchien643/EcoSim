# ============================================================
# EcoSim — Economic Campaign Simulation Platform
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider (OpenAI-compatible) ---
# Supports: OpenAI, Groq, Together AI, Ollama (change base_url)
#
# Performance tip cho KG build: Groq + Llama 3.3 70B nhanh hơn ~5-10× OpenAI
# gpt-4o-mini cùng quality. Sample config:
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL_NAME=llama-3.3-70b-versatile
#   LLM_EXTRACTION_MODEL=llama-3.3-70b-versatile
# Cerebras nhanh hơn nữa (~10×):
#   LLM_BASE_URL=https://api.cerebras.ai/v1
#   LLM_MODEL_NAME=llama-3.3-70b
# AVOID local Ollama nhỏ < 7B vì JSON mode (response_format) chưa stable.
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Optional: cheaper/faster model for interview classifier + in-character replies
# (reused by any future "selective-context" flows — Survey conduct, Report's
# interview_agents tool). Default = LLM_MODEL_NAME if unset.
# Examples: gpt-3.5-turbo, gpt-4o-mini, llama-3.1-8b-instant (Groq),
# llama3.1:8b (Ollama local).
LLM_FAST_MODEL_NAME=

# STRONGER model cho stages chiết xuất tài liệu (KG build pipeline):
#   Stage 1 (CampaignParser): file → CampaignSpec
#   Stage 3 (CampaignSectionAnalyzer): section → entities + facts
# Đắt hơn ~5× LLM_MODEL_NAME nhưng precision cao hơn cho Vietnamese business
# docs (ít nhầm "Brand"→"Company", catch implicit relationships). Cost mitigated
# bởi cache: extracted/sections.json + analyzed.json persist sau lần build đầu,
# build sau reuse cache (skip LLM stages).
# Force re-extract: rm -rf data/uploads/<campaign_id>/extracted/
LLM_EXTRACTION_MODEL=gpt-4o

# --- Embedding (centralized — used by Graphiti KG + ChromaDB posts) ---
# Mọi vector embedding đi qua LLMClient.embed* với cấu hình dưới đây để
# đảm bảo Graphiti (KG vectors) và ChromaDB (post vectors) cùng vector space.
# Default: text-embedding-3-small (OpenAI, 1536-dim, ~$0.02/1M tokens).
LLM_EMBEDDING_MODEL=text-embedding-3-small
# Optional: tách endpoint cho embedding nếu chat provider không support
# (vd Groq chỉ có chat, fallback OpenAI cho embeddings). Default = LLM_BASE_URL.
LLM_EMBEDDING_BASE_URL=
# Optional: tách api key cho embedding endpoint. Default = LLM_API_KEY.
LLM_EMBEDDING_API_KEY=

# --- Zep Cloud (managed KG extraction, optional) ---
# Đăng ký tại https://www.getzep.com → API key bắt đầu bằng `z_...`.
# Free tier: 1000 credits/tháng (~28-33 builds doc 10KB). Flex $125/tháng.
# Bắt buộc khi KG_BUILDER=zep_hybrid. Empty/missing → fall back direct path.
ZEP_API_KEY=

# KG build engine selection:
#   zep_hybrid : Zep server-side LLM extract → mirror FalkorDB (rich info, ~30-60s)
#   direct     : Stage 2 EcoSim extract → direct Cypher write (fast 12s, info-lossy)
#   graphiti   : Legacy Graphiti add_episode (60+ phút, debug only)
# Default = direct cho dev. Switch zep_hybrid khi cần rich attributes/temporal.
KG_BUILDER=direct

# --- Phase 15: Sim runtime — section-per-action via Zep ---
# Khi true: cuối mỗi round, content actions (create_post + create_comment với
# content >=30 chars) được convert thành section text natural Vietnamese (1
# section/action), submit batch qua zep.graph.add_batch + poll → fetch
# nodes/edges/episodes → re-embed local → Cypher MERGE vào FalkorDB sim_<sid>
# + reroute Zep-extracted Agent → seeded SimAgent.
# Structural data (like/follow/vote/repost) sống trong oasis_simulation.db
# SQL — KHÔNG ghi graph (Phase 13).
# Cost: ~5-15 Zep credits/round × 5-10 rounds = 25-150 credits/sim.
# Free tier 1000/mo → ~7-20 sims/month. Production Flex $25/mo.
# Yêu cầu ZEP_API_KEY set. Default: true. Graceful skip nếu key missing —
# sim chạy bình thường, mất KG semantic layer (cognitive helper degrade
# tới master clone).
ZEP_SIM_RUNTIME=true

# --- FalkorDB (Knowledge Graph) ---
# Start with: docker compose up -d
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_BOLT_PORT=7687

# --- Flask ---
FLASK_DEBUG=true
FLASK_PORT=5000
MAX_UPLOAD_SIZE_MB=50

# --- Directories ---
# Phase 5: default = `data/campaigns/` (was uploads/). Bỏ comment để override.
# CAMPAIGNS_DIR=data/campaigns
